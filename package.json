{
  "name": "re-hana-counter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "bun test --timeout 10000",
    "typecheck": "tsc -b && tsc -p test/tsconfig.json",
    "lint": "biome lint",
    "format": "biome format --write",
    "format:check": "biome format",
    "knip": "knip",
    "preview": "bun run build && vite preview",
    "deploy": "bun run build && wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "hono": "^4.12.25",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.17.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@cloudflare/vite-plugin": "^1.40.2",
    "@happy-dom/global-registrator": "^20.10.2",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "knip": "^6.16.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "wrangler": "^4.100.0"
  }
}
